#define CPPHTTPLIB_OPENSSL_SUPPORT

Définition nécessaire pour Windows 10+.

Active le support OpenSSL pour httplib.

#include <SDL.h>
#include "imgui.h"
#include "backends/imgui_impl_sdl2.h"
#include "backends/imgui_impl_sdlrenderer2.h"
#include "httplib_openssl/include/httplib.h"
#include "json.hpp"
#include <string>
#include <thread>
#include <mutex>
#include <iostream>
#include <atomic>
#include <chrono>

Inclusion de toutes les bibliothèques nécessaires :

SDL2 + ImGui → UI.

httplib + json → requête API et parsing JSON.

thread, mutex, atomic, chrono → pour le thread AI et sécurité.

Variables globales
std::string ai_response = "Salut ! Pose ta question.";
std::string question_pending = "";
std::mutex mtx;
std::atomic<bool> run_ai_thread(true);
std::string token = "";

ai_response → ce que l’AI renvoie, affiché dans l’UI.

question_pending → stocke la dernière question à envoyer à l’AI.

mtx → protège l’accès concurrent à ces variables.

run_ai_thread → pour savoir si le thread doit continuer.

token → ta clé HuggingFace.

Fonction AI
void ask_ai(const std::string& question) {
    try {
        httplib::SSLClient cli("router.huggingface.co", 443);
        cli.set_follow_location(true);

        httplib::Headers headers = {
            {"Authorization", "Bearer " + token},
            {"Content-Type", "application/json"}
        };

        std::string body = R"({
            "model": "Qwen/Qwen3.5-397B-A17B:novita",
            "messages": [{"role": "user", "content": ")" + question + R"("}]
        })";

Création d’un client HTTPS pour HuggingFace.

Définition des headers pour authentification et type JSON.

Construction du JSON pour envoyer la question au modèle.

        auto res = cli.Post("/v1/chat/completions", headers, body, "application/json");

        std::string reply = "Request failed";
        if (res) {
            try {
                json j = json::parse(res->body);
                reply = j["choices"][0]["message"]["content"];
            } catch (...) {
                reply = "Erreur parse JSON";
            }
        }

        std::lock_guard<std::mutex> lock(mtx);
        ai_response = reply;

    } catch (...) {
        std::lock_guard<std::mutex> lock(mtx);
        ai_response = "Erreur requête AI";
    }
}

Envoie la requête POST.

Parse le JSON pour récupérer le message de l’AI.

lock_guard protège ai_response pendant la mise à jour.

Capture toutes les exceptions pour éviter que l’app plante.

Thread permanent pour l’AI
void ai_thread_func() {
    while (run_ai_thread) {
        std::string question;
        {
            std::lock_guard<std::mutex> lock(mtx);
            question = question_pending;
            question_pending.clear(); // on consomme la question
        }

        if (!question.empty()) {
            ask_ai(question); // met à jour ai_response
        } else {
            std::this_thread::sleep_for(std::chrono::milliseconds(50));
        }
    }
}

Thread permanent qui vérifie question_pending.

Si une question est présente, appelle ask_ai.

Si pas de question, fait un petit sleep pour ne pas saturer le CPU.

La mutex protège l’accès à question_pending et ai_response.

Main SDL + ImGui
int SDL_main(int, char**) {
    SDL_Init(SDL_INIT_VIDEO);
    SDL_Window* window = SDL_CreateWindow("Chat AI Simple",
                                          SDL_WINDOWPOS_CENTERED,
                                          SDL_WINDOWPOS_CENTERED,
                                          800, 600,
                                          SDL_WINDOW_ALLOW_HIGHDPI);
    SDL_Renderer* renderer = SDL_CreateRenderer(window, -1, SDL_RENDERER_ACCELERATED);

Initialise SDL2.

Crée la fenêtre et le renderer pour ImGui.

    ImGui::CreateContext();
    ImGui_ImplSDL2_InitForSDLRenderer(window, renderer);
    ImGui_ImplSDLRenderer2_Init(renderer);

    char input_text[256] = "";
    bool run = true;

    std::thread ai_thread(ai_thread_func); // Lancer le thread permanent

Initialise ImGui.

Crée un thread permanent pour gérer les questions AI.

Boucle principale UI
    while (run) {
        SDL_Event event;
        while (SDL_PollEvent(&event)) {
            if (event.type == SDL_QUIT) run = false;
            ImGui_ImplSDL2_ProcessEvent(&event);
        }

        ImGui_ImplSDLRenderer2_NewFrame();
        ImGui_ImplSDL2_NewFrame();
        ImGui::NewFrame();

Lit les événements SDL (fermeture fenêtre).

Démarre une nouvelle frame ImGui.

        ImGui::Begin("Chat AI Simple");
        ImGui::TextWrapped("Pose ta question et clique sur Envoyer.");

        ImGui::InputText("##input", input_text, sizeof(input_text));

        if (ImGui::Button("Envoyer")) {
            if (strlen(input_text) > 0) {
                std::lock_guard<std::mutex> lock(mtx);
                question_pending = input_text; // nouvelle question
                input_text[0] = '\0';          // vide le champ
            }
        }

        {
            std::lock_guard<std::mutex> lock(mtx);
            ImGui::TextWrapped("%s", ai_response.c_str());
        }

        ImGui::End();

Affiche le champ de texte et le bouton.

Envoie la question dans question_pending.

Affiche la réponse AI.

        ImGui::Render();
        SDL_SetRenderDrawColor(renderer, 25, 25, 40, 255);
        SDL_RenderClear(renderer);
        ImGui_ImplSDLRenderer2_RenderDrawData(ImGui::GetDrawData(), renderer);
        SDL_RenderPresent(renderer);
    }

Render final de la frame avec SDL2 et ImGui.

Fermeture propre
    run_ai_thread = false;
    ai_thread.join();

    ImGui_ImplSDLRenderer2_Shutdown();
    ImGui_ImplSDL2_Shutdown();
    ImGui::DestroyContext();
    SDL_DestroyRenderer(renderer);
    SDL_DestroyWindow(window);
    SDL_Quit();

    return 0;
}

Stoppe le thread permanent AI.

Ferme ImGui et SDL correctement.

Évite les fuites de mémoire et crash.






+----------------+
|  ImGui Window  |  <- SDL2 gère la fenêtre et les événements
+----------------+
       |
       v
+----------------+
| InputText      |  <- l'utilisateur tape une question
+----------------+
       |
       v
+----------------+
| Button Envoyer |
+----------------+
       |
       v
[Écrit question dans "question_pending"]
       |
       v
+----------------+   (mutex protège accès)
| Thread AI      |  <- thread permanent
+----------------+
       |
       v
[Lit question_pending]
       |
       v
+----------------+
| ask_ai()       |  <- envoie requête HTTPS à HuggingFace
+----------------+
       |
       v
[Parse JSON et met à jour ai_response]
       |
       v
+----------------+
| ImGui Display  |  <- affiche ai_response dans la fenêtre
+----------------+
       |
       v
[Utilisateur voit la réponse et peut taper autre question]